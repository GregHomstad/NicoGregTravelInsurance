# BMI Travel Assist API credentials
# Copy this file to .env and fill in your values (never commit .env)
# For production, use the encrypted vault instead:
#   set VAULT_KEY=your-master-password && node server/vault.js encrypt
BMI_API_BASE=https://api.bmicos.com/bmiecommerce/sandbox/v4
BMI_AUTH_USER=your_auth_user_here
BMI_AUTH_KEY=your_auth_key_here
BMI_AGENT_ID=16111

# Proxy API key — required for frontend → proxy authentication
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PROXY_API_KEY=your_api_key_here

# Vault master key (used to decrypt vault.enc at startup)
# VAULT_KEY=your-master-password

# Server port (default: 3001)
PORT=3001

# Allowed CORS origins — comma-separated, no spaces
# Development: http://localhost:5173,http://localhost:3000
# Production: https://tripkavach.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
